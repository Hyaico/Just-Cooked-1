{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/recipe/:shareId",
      "destination": "https://sglxaaehziokuimtnnqw.supabase.co/functions/v1/serve-shared-recipe/:shareId"
    }
  ],
  "headers": [
    {
      "source": "/recipe/:shareId",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ]
    }
  ]
}
